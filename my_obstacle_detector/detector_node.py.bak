import rclpy
from rclpy.node import Node
from sensor_msgs.msg import LaserScan

class DetectorNode(Node):
    def __init__(self):
        super().__init__('detector_node')
        # YDLidar X2의 QoS에 맞춰 Best Effort(sensor_data)로 구독
        # 이부분은 받아들일 메시지 토픽을 입력하여 데이터 구독자 초기화
        self.subscription = self.create_subscription(
            LaserScan, # 타입
            '/scan', # 토픽
            self.scan_callback, # 실행 콜백 함수
            rclpy.qos.qos_profile_sensor_data # qos 데이터 통신 정책 선택
        )
        self.get_logger().info('장애물 감지 노드가 실행되었습니다.')

    def scan_callback(self, msg):
        # YDLidar X2 기준: 배열의 앞부분(0도 근처)이 정면입니다.
        # 정면 좌우 20도씩, 총 40도 범위를 체크해봅시다.
        # 인덱스 계산: degree = index * angle_increment
        
        front_degrees = 20 
        # 각도 간격이 보통 1도라고 가정하면 앞/뒤 인덱스를 추출
        num_points = len(msg.ranges)
        
        # 0도 기준 좌우 데이터를 슬라이싱 (배열의 처음과 끝 부분)
        # YDLidar의 특성에 따라 정면 인덱스가 다를 수 있으니 확인이 필요합니다.
        front_ranges = msg.ranges[:front_degrees] + msg.ranges[-front_degrees:]
        
        # 유효한 거리 값 중 최솟값 찾기
        valid_ranges = [r for r in front_ranges if msg.range_min < r < msg.range_max]
        
        if valid_ranges:
            min_dist = min(valid_ranges)
            if min_dist < 0.5: # 0.5m 이내 장애물 감지
                self.get_logger().warn(f'🚨 장애물 근접! 거리: {min_dist:.2f}m')
            else:
                self.get_logger().info(f'전방 클리어: {min_dist:.2f}m')

def main(args=None):
    rclpy.init(args=args)
    node = DetectorNode()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()
